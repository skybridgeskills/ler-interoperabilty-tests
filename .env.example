# LER Interoperability Test Suite — example environment

# CONTEXT controls which AppContext the server boots into:
#   dev    — pino-pretty logger, real time/id services
#   test   — silent logger, deterministic time/id services
#   hosted — plain JSON pino logger (for log aggregation), real time/id services
CONTEXT=dev

# pino log level (silent | error | warn | info | debug | trace)
# LOG_LEVEL=info

# Periodic health-snapshot logging (structured logs → Loki → Grafana).
# Disabled only when HEALTH_SNAPSHOT_ENABLED is exactly "false"; an interval
# <= 0 also disables it. Defaults shown.
# HEALTH_SNAPSHOT_ENABLED=true
# HEALTH_SNAPSHOT_INTERVAL_MS=60000

# ------------------------------------------------------------------------------
# Exchange runner — local DCC dependency services
# See docker/README.md for the full setup runbook.
# ------------------------------------------------------------------------------

# Toggle the in-app exchange runner. When false, the runnable wallet acceptance
# page renders a disabled-state hint instead of the live CTA.
EXCHANGE_RUNNER_ENABLED=false

# Where the suite's server endpoints reach the transaction service. Inside
# docker compose this stays http://localhost:4004 because compose maps the
# container port to the host.
TRANSACTION_SERVICE_URL=http://localhost:4004

# Tenant identity the suite presents to the transaction service.
TRANSACTION_SERVICE_TENANT_NAME=default
TRANSACTION_SERVICE_TENANT_TOKEN=replace-me-in-.env

# ------------------------------------------------------------------------------
# Variables passed through to the docker compose containers (NOT read by the
# SvelteKit app directly). Keep TENANT_TOKEN_DEFAULT identical to
# TRANSACTION_SERVICE_TENANT_TOKEN above.
# ------------------------------------------------------------------------------

# Public URL the transaction service embeds in interaction URLs / QR codes.
# Override for cross-device wallet testing (e.g. an ngrok tunnel).
DEFAULT_EXCHANGE_HOST=http://localhost:4004

# Tenant Bearer token the transaction service accepts for the `default` tenant.
TENANT_TOKEN_DEFAULT=replace-me-in-.env

# OAuth2 access-JWT secret used by the transaction service.
ACCESS_JWT_SECRET=replace-me-with-a-long-random-string
